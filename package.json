{
  "name": "Zentry",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": "Steve",
  "scripts": {
    "tail-watch": "bunx tailwindcss -i ./src/index.css -o ./src/tailwind.css --watch",
    "app-watch": "bun --hot src/index.ts",
    "dev": "concurrently \"bun tail-watch\" \"bun app-watch\"",
    "builder": "bunx @tailwindcss/cli -i ./src/index.css -o ./src/tailwind.css --minify && bun build ./src/index.html --outdir=dist --sourcemap --target=browser --minify --define:process.env.NODE_ENV='\"production\"' --env='BUN_PUBLIC_*'",
    "start": "NODE_ENV=production bun src/index.ts",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "gsap": "^3.14.2",
    "lucide-react": "^0.563.0",
    "radix-ui": "^1.4.3",
    "react": "^19",
    "react-dom": "^19",
    "react-icons": "^5.6.0",
    "react-router-dom": "^7.13.1",
    "react-use": "^17.6.0",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/bun": "latest",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "jsdom-quokka-plugin": "^1.0.16",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1"
  }
}
